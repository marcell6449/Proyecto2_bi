                        <SqlSelectItem Type="Column" Name="nombre" ColumnType="Text" />
                        <SqlSelectItem Type="Column" Name="tipo_producto" ColumnType="Text" />
                        <SqlSelectItem Type="Column" Name="descripcion" ColumnType="Text" />
