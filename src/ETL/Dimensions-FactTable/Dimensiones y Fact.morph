                        <SqlSelectItem Type="Column" Name="modificado_en" ColumnType="DateTime" />
                      </SelectItems>
                      <Expressions />
                      <WhereConditionTree />
                      <HavingConditionTree />
                    </QueryModel>
                    <Parameters />
                  </Query>
                </ImportSqlAction>
                <ReplaceColumnsAction>
                  <Columns>
                    <NameExpressionPair Name="codigo_categoria">
                      <Expression Value="if([nombre] = &quot;Soluble&quot;, &quot;SO&quot;,&#xD;&#xA;if([nombre] = &quot;Granular&quot;, &quot;GR&quot;,&#xD;&#xA;if([nombre] = &quot;Otros&quot;, &quot;OT&quot;,&#xD;&#xA;if([nombre] = &quot;Liquidos&quot;, &quot;LI&quot;,&#xD;&#xA;if([nombre] = &quot;Material para Invernaderos&quot;, &quot;MI&quot;,&#xD;&#xA;if([nombre] = &quot;Sustrato&quot;, &quot;SU&quot;,&#xD;&#xA;&quot;ND&quot;))))))" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="tipo_producto">
                      <Expression Value="if([nombre] = &quot;Sin Categoría&quot;, &quot;Categoría no definida o no identificada.&quot;,&#xD;&#xA;if([nombre] = &quot;Soluble&quot;, &quot;Solubles&quot;,&#xD;&#xA;if([nombre] = &quot;Granular&quot;, &quot;Granulares&quot;,&#xD;&#xA;if([nombre] = &quot;Otros&quot;, &quot;Varios&quot;,&#xD;&#xA;if([nombre] = &quot;Liquidos&quot;, &quot;Liquido&quot;,&#xD;&#xA;if([nombre] = &quot;Material para Invernaderos&quot;, &quot;Materiales&quot;,&#xD;&#xA;if([nombre] = &quot;Sustrato&quot;, &quot;Sustratos&quot;,&#xD;&#xA;&quot;&quot;)))))))" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="descripcion">
                      <Expression Value="if([nombre] = &quot;Sin Categoría&quot;, &quot;Categoría no definida o no identificada.&quot;,&#xD;&#xA;if([nombre] = &quot;Soluble&quot;, &quot;Productos fertilizantes solubles.&quot;,&#xD;&#xA;if([nombre] = &quot;Granular&quot;, &quot;Productos fertilizantes granulares.&quot;,&#xD;&#xA;if([nombre] = &quot;Otros&quot;, &quot;Productos que no pertenecen a una categoría específica.&quot;,&#xD;&#xA;if([nombre] = &quot;Liquidos&quot;, &quot;Fertilizantes, bioestimulantes y productos líquidos.&quot;,&#xD;&#xA;if([nombre] = &quot;Material para Invernaderos&quot;, &quot;Materiales para invernaderos, coberturas, bandejas y accesorios.&quot;,&#xD;&#xA;if([nombre] = &quot;Sustrato&quot;, &quot;Sustratos y medios de crecimiento para cultivos.&quot;,&#xD;&#xA;&quot;&quot;)))))))" Type="Expression" />
                    </NameExpressionPair>
                  </Columns>
                </ReplaceColumnsAction>
                <ExportDbAction AutoStatus="true" UseCustomSql="false" CustomSql="" BatchSize="100" ColumnTypeMismatchOption="FailBatch" BatchFailureOption="Halt" ColumnMappingMode="Explicit">
