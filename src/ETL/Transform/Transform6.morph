                <LookupAction LookupTableName="fertiliza_oltp.movimiento_inventario 1" SecondTableExists="true" ColumnName="id_producto" LookupColumnName="id_producto" ReturnColumnName="fecha_movimiento" CreateNewColumn="true" ValueNotFoundOption="MakeEmpty" />
                <RenameColumnsAction>
                  <Names>
                    <NamePair Name1="fecha_movimiento" Name2="ultima_modificacion" />
                  </Names>
                </RenameColumnsAction>
                <AddColumnsAction ColumnExistsOption="Rename">
                  <Columns>
                    <NameExpressionPair Name="dias_inventariado">
                      <Expression Value="#2026-05-08 - [ultima_modificacion]" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="color_semaforo">
                      <Expression Value="if(isempty([ultima_modificacion]), &quot;Revisión&quot;,&#xD;&#xA;if([dias_inventariado] &lt;= 90, &quot;Verde&quot;,&#xD;&#xA;if([dias_inventariado] &lt;= 365, &quot;Amarillo&quot;,&#xD;&#xA;&quot;Rojo&quot;)))" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="id_semaforo">
                      <Expression Value="if(isempty([ultima_modificacion]), 4,&#xD;&#xA;if([dias_inventariado] &lt;= 90, 1,&#xD;&#xA;if([dias_inventariado] &lt;= 365, 2,&#xD;&#xA;3)))" Type="Expression" />
                    </NameExpressionPair>
                  </Columns>
                  <InsertPosition Position="Rightmost" />
                </AddColumnsAction>
                <LookupAction LookupTableName="fertiliza_oltp.producto 1" SecondTableExists="true" ColumnName="id_producto" LookupColumnName="id_producto" ReturnColumnName="id_marca" CreateNewColumn="true" ValueNotFoundOption="MakeEmpty" />
