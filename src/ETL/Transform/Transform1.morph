                  <Columns>
                    <NameExpressionPair Name="categoria_jerarquizada">
                      <Expression Value="if(&#xD;&#xA;   Upper(Trim([categoria_raw])) = &quot;GRANULAR - SOLUBLES&quot;,&#xD;&#xA;&#xD;&#xA;   if(&#xD;&#xA;      Contains(Upper([nombre_raw]),&quot;WG&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;DAP&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;UREA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;NPK&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;YARAMILA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;YARABELA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;YARAVERA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;GRANUPOTASE&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;DOLOMAG&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;AZUFERTIL&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;GRANUMAX&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;MOP&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;MF &quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;NITRO XTEND&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;NUTRIMON&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;PRODUMON&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;ENPALMA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;NITRASAM&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;SEMBRAMON&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;NUTRICARGA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;CAL DOLOMITA&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;CALIX&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;CALIX PURE&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;TALANTE&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;THIAMETOXAN&quot;),&#xD;&#xA;      &quot;Granular&quot;,&#xD;&#xA;&#xD;&#xA;      if(&#xD;&#xA;         Contains(Upper([nombre_raw]),&quot;WP&quot;)&#xD;&#xA;         