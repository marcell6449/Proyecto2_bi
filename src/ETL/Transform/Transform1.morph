INVERNADEROS - SUSTRATO Y OTROS&quot;,&#xD;&#xA;&#xD;&#xA;      if(&#xD;&#xA;         Contains(Upper([nombre_raw]),&quot;SUSTRATO&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;COCO MIX&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;TURBA&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;PERLITAS&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;BOLSA DE CRECIMIENTO&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;70/30&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;SC18L&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;SC12L&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot;ESSE SC&quot;),&#xD;&#xA;         &quot;Sustrato&quot;,&#xD;&#xA;&#xD;&#xA;         if(&#xD;&#xA;            Contains(Upper([nombre_raw]),&quot;JIFFY&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;CANALETA&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;SARAN&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;MULCH&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;GROUND COVER&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;MANTA AGRICOLA&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;SPACER&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;MACETA&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;BANDEJA&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;PELLET&quot;),&#xD;&#xA;            &quot;Material para Invernaderos&quot;,&#xD;&#xA;            &quot;Otros&quot;&#xD;&#xA;         )&#xD;&#xA;      ),&#xD;&#xA;&#xD;&#xA;      [categoria_raw]&#xD;&#xA;   )&#xD;&#xA;)" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="revision_manual">
                      <Expression Value="if(&#xD;&#xA;   Upper(Trim([categoria_jerarquizada])) = &quot;SOLUBLE&quot;&#xD;&#xA;   or Upper(Trim([categoria_jerarquizada])) = &quot;GRANULAR&quot;&#xD;&#xA;   or Upper(Trim([categoria_jerarquizada])) = &quot;LIQUIDOS&quot;&#xD;&#xA;   or Upper(Trim([categoria_jerarquizada])) = &quot;MATERIAL PARA INVERNADEROS&quot;&#xD;&#xA;   or Upper(Trim([categoria_jerarquizada])) = &quot;SUSTRATO&quot;&#xD;&#xA;   or Upper(Trim([categoria_jerarquizada])) = &quot;OTROS&quot;,&#xD;&#xA;   &quot;OK&quot;,&#xD;&#xA;   &quot;REVISAR&quot;&#xD;&#xA;)" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="marca">
                      <Expression Value="if(&#xD;&#xA;   StartsWith(Upper(Trim([codigo_raw])),&quot;ABP&quot;),&#xD;&#xA;   &quot;ABP&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   StartsWith(Upper(Trim([nombre_raw])),&quot;BIO &quot;)&#xD;&#xA;   or StartsWith(Upper(Trim([nombre_raw])),&quot;BIO -&quot;),&#xD;&#xA;   &quot;Biovenko&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;ABP -&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;ABP-&quot;),&#xD;&#xA;   &quot;ABP&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;BRANDT&quot;),&#xD;&#xA;   &quot;Brandt&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;FERTILISA&quot;),&#xD;&#xA;   &quot;Fertilisa&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;JIFFY&quot;),&#xD;&#xA;   &quot;Jiffy&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;MANVERT&quot;),&#xD;&#xA;   &quot;Manvert&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;MANTTRA&quot;),&#xD;&#xA;   &quot;Manttra&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;MF &quot;),&#xD;&#xA;   &quot;MF (Mosaic Fertilizantes)&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;NORDOX&quot;),&#xD;&#xA;   &quot;Nordox&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;NUTRIMON&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;MONOMEROS&quot;),&#xD;&#xA;   &quot;Monomeros&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;OPISTRA&quot;),&#xD;&#xA;   &quot;Opistra&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;QUIVER&quot;),&#xD;&#xA;   &quot;Quiver&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;YARAMILA&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;YARALIVA&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;YARATERA&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;YARAVERA&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;YARABELA&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot;YARA&quot;),&#xD;&#xA;   &quot;Yara&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;POEMA&quot;),&#xD;&#xA;   &quot;POEMA&quot;,&#xD;&#xA;&#xD;&#xA;if(&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot;GRANUPOTASE&quot;),&#xD;&#xA;   &quot;Haifa&quot;,&#xD;&#xA;&#xD;&#xA;   &quot;Desconocido&quot;&#xD;&#xA;))))))))))))))))" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="unidad">
                      <Expression Value="if(&#xD;&#xA;&#xD;&#xA;   Contains(Upper([nombre_raw]),&quot; GRAMOS&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot; 250 G&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot; 500 G&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot; 100 G&quot;)&#xD;&#xA;   or Contains(Upper([nombre_raw]),&quot; G)&quot;),&#xD;&#xA;&#xD;&#xA;   &quot;G&quot;,&#xD;&#xA;&#xD;&#xA;   if(&#xD;&#xA;&#xD;&#xA;      Contains(Upper([nombre_raw]),&quot; KG&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot;KG&quot;)&#xD;&#xA;      or Contains(Upper([nombre_raw]),&quot; KGS&quot;),&#xD;&#xA;&#xD;&#xA;      &quot;Kg&quot;,&#xD;&#xA;&#xD;&#xA;      if(&#xD;&#xA;&#xD;&#xA;         Contains(Upper([nombre_raw]),&quot; GALON&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot; GAL &quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot; GALONES&quot;)&#xD;&#xA;         or Contains(Upper([nombre_raw]),&quot; 2.5 GAL&quot;),&#xD;&#xA;&#xD;&#xA;         &quot;Gal&quot;,&#xD;&#xA;&#xD;&#xA;         if(&#xD;&#xA;&#xD;&#xA;            Contains(Upper([nombre_raw]),&quot; LT&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot; LTS&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot; 20L&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot; 10L&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot; 5 L&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot; 1 LT&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;SC18L&quot;)&#xD;&#xA;            or Contains(Upper([nombre_raw]),&quot;SC12L&quot;),&#xD;&#xA;&#xD;&#xA;            &quot;Lt&quot;,&#xD;&#xA;&#xD;&#xA;            if(&#xD;&#xA;&#xD;&#xA;               Contains(Upper([nombre_raw]),&quot;CJ&quot;),&#xD;&#xA;&#xD;&#xA;               &quot;CJ&quot;,&#xD;&#xA;&#xD;&#xA;               if(&#xD;&#xA;&#xD;&#xA;                  Contains(Upper([nombre_raw]),&quot;ROLLO&quot;)&#xD;&#xA;                  or Contains(Upper([nombre_raw]),&quot;SARAN&quot;)&#xD;&#xA;                  or Contains(Upper([nombre_raw]),&quot;GROUND COVER&quot;)&#xD;&#xA;                  or Contains(Upper([nombre_raw]),&quot;MULCH&quot;)&#xD;&#xA;                  or Contains(Upper([nombre_raw]),&quot;MANTA AGRICOLA&quot;),&#xD;&#xA;&#xD;&#xA;                  &quot;Ro&quot;,&#xD;&#xA;&#xD;&#xA;                  &quot;Un&quot;&#xD;&#xA;&#xD;&#xA;               )&#xD;&#xA;&#xD;&#xA;            )&#xD;&#xA;&#xD;&#xA;         )&#xD;&#xA;&#xD;&#xA;      )&#xD;&#xA;&#xD;&#xA;   )&#xD;&#xA;&#xD;&#xA;)" Type="Expression" />
                    </NameExpressionPair>
                    <NameExpressionPair Name="presentacion">
                      <Expression Value="if(&#xD;&#xA;&#xD;&#xA;   IsRegExMatch(Upper([nombre_raw]),&quot;CJ\d+&quot;),&#xD;&#xA;&#xD;&#xA;   RegExMatch(Upper([nombre_raw]),&quot;CJ\d+&quot;),&#xD;&#xA;&#xD;&#xA;   if(&#xD;&#xA;&#xD;&#xA;      IsRegExMatch(&#xD;&#xA;         Upper([nombre_raw]),&#xD;&#xA;         &quot;\d+([.,]\d+)?\s*(KG|KGS|LT|LTS|G|GRAMOS|LB)&quot;&#xD;&#xA;      ),&#xD;&#xA;&#xD;&#xA;      RegExMatch(&#xD;&#xA;         Upper([nombre_raw]),&#xD;&#xA;         &quot;\d+([.,]\d+)?\s*(KG|KGS|LT|LTS|G|GRAMOS|LB)&quot;&#xD;&#xA;      ),&#xD;&#xA;&#xD;&#xA;      if(&#xD;&#xA;&#xD;&#xA;         IsRegExMatch(&#xD;&#xA;            Upper([nombre_raw]),&#xD;&#xA;            &quot;\d+([.,]\d+)?M&quot;&#xD;&#xA;         ),&#xD;&#xA;&#xD;&#xA;         RegExMatch(&#xD;&#xA;            Upper([nombre_raw]),&#xD;&#xA;            &quot;\d+([.,]\d+)?M&quot;&#xD;&#xA;         ),&#xD;&#xA;&#xD;&#xA;         Empty()&#xD;&#xA;&#xD;&#xA;      )&#xD;&#xA;&#xD;&#xA;   )&#xD;&#xA;&#xD;&#xA;)" Type="Expression" />
